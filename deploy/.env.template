# Margaux secrets template · COPY to .env, fill on the VPS, NEVER commit (.gitignore blocks it).
# Contractor terminals get NON-PROD test values from the shared secret store (n8n
# credentials / Supabase Vault), never from a Mac file and never hardcoded.

# --- Claude (the brain) ---
ANTHROPIC_API_KEY=

# --- Supabase (shared state) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=      # worker writes with this (server-side only)
SUPABASE_ANON_KEY=              # Netlify dashboard read-only
SUPABASE_FRAMES_BUCKET=margaux-frames

# --- Discord (interface) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=             # Margaux's channel
DISCORD_COMMAND_CENTER_WEBHOOK= # command-center rollup channel

# --- rclone / Google Drive (headless OAuth on the VPS, NOT the Mac desktop mount) ---
RCLONE_DRIVE_REMOTE=gdrive
# rclone config lives at /root/.config/rclone/rclone.conf on Hermes (token, not a file path dep)

# --- whisper on Linux (env-driven model path, no ~/ Mac defaults) ---
WHISPER_CPP_MODEL=/opt/whisper/models/ggml-medium.bin

# --- Blotato (publish) ---
# ROTATE FIRST: the current Blotato key LEAKED. Generate a new one, revoke the old,
# store here, and never put it in git or content-data.js.
BLOTATO_API_KEY=

# --- worker runtime ---
MARGAUX_WORKDIR=/var/margaux/work    # absolute VPS working dir (not $HOME, not the Mac)
MARGAUX_MAX_CONCURRENT_JOBS=2
MARGAUX_DISK_BUDGET_GB=40
